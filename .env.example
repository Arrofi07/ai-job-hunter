# Copy this to .env and fill in real values. Never commit .env itself.

# --- LLM provider routing (see app/config.py for full explanation) ---
# Which provider handles which kind of task by default:
LLM_PROVIDER_NUANCED=gemini
LLM_PROVIDER_STRUCTURED=groq
# Automatic fallback target if the primary provider rate-limits:
LLM_FALLBACK_PROVIDER=ollama
# Emergency override: force ALL tasks onto one provider (leave blank normally).
# Set this to "groq" or "ollama" if Gemini is rate-limited for a while.
LLM_FORCE_PROVIDER=

# --- Provider credentials ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama runs locally, no API key. Install from https://ollama.com,
# then `ollama pull llama3.1` (or whatever model you set below) and
# `ollama serve` before this app tries to use it.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- Storage ---
DATABASE_URL=postgresql+psycopg2://jobhunter:jobhunter@localhost:5432/jobhunter
QDRANT_URL=http://localhost:6333

# --- Google Drive (filled in during Slice 2) ---
GDRIVE_ROOT_FOLDER_NAME=AI Job Hunter
